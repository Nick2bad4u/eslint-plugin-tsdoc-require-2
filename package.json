{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "eslint-plugin-tsdoc-require-2",
    "version": "1.0.0",
    "description": "Require TSDoc comments for exported TypeScript declarations.",
    "keywords": [
        "eslint",
        "eslint-plugin",
        "eslintplugin",
        "typescript",
        "tsdoc",
        "jsdoc"
    ],
    "homepage": "https://github.com/Nick2bad4u/eslint-plugin-tsdoc-require-2#readme",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/eslint-plugin-tsdoc-require-2/issues",
        "email": "20943337+Nick2bad4u@users.noreply.github.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/eslint-plugin-tsdoc-require-2.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://nick2bad4u.github.io/eslint-plugin-typefest)",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://nick2bad4u.github.io/eslint-plugin-typefest"
        }
    ],
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/plugin.d.ts",
            "import": "./dist/plugin.js",
            "default": "./dist/plugin.js"
        }
    },
    "main": "./dist/plugin.js",
    "types": "./dist/plugin.d.ts",
    "files": [
        "dist",
        "docs/rules",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "changelog:release-notes": "node ./scripts/changelog-release-notes.mjs",
        "clean": "rimraf coverage dist temp .cache/tsbuildinfo",
        "lint": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache",
        "lint:compat:eslint": "node ./scripts/eslint-compat-smoke.mjs",
        "lint:compat:eslint10": "npm run lint:compat:eslint -- --expect-eslint-major=10",
        "lint:compat:eslint9": "npm run lint:compat:eslint -- --expect-eslint-major=9",
        "lint:fix": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache --fix",
        "release:check": "npm run clean && npm run build && npm run typecheck && npm run lint && npm run test",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.eslint.json --noEmit && tsc -p tsconfig.js.json --noEmit"
    },
    "dependencies": {
        "@typescript-eslint/utils": "^8.56.1"
    },
    "devDependencies": {
        "@docusaurus/eslint-plugin": "^3.9.2",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
        "@eslint-react/eslint-plugin": "^2.13.0",
        "@eslint/compat": "^2.0.3",
        "@eslint/config-helpers": "^0.5.3",
        "@eslint/css": "^0.14.1",
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.0.1",
        "@eslint/markdown": "^7.5.1",
        "@html-eslint/eslint-plugin": "^0.58.1",
        "@html-eslint/parser": "^0.58.1",
        "@microsoft/eslint-plugin-sdl": "^1.1.0",
