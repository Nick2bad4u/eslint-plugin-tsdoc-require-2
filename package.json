{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "eslint-plugin-tsdoc-require-2",
    "version": "1.0.7",
    "private": false,
    "description": "Require TSDoc comments for exported TypeScript declarations.",
    "keywords": [
        "eslint",
        "eslint-plugin",
        "eslintplugin",
        "typescript",
        "tsdoc",
        "jsdoc"
    ],
    "homepage": "https://github.com/Nick2bad4u/eslint-plugin-tsdoc-require-2#readme",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/eslint-plugin-tsdoc-require-2/issues",
        "email": "20943337+Nick2bad4u@users.noreply.github.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/eslint-plugin-tsdoc-require-2.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://nick2bad4u.github.io/eslint-plugin-tsdoc-require-2)",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://nick2bad4u.github.io/eslint-plugin-tsdoc-require-2"
        }
    ],
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/plugin.d.ts",
                "default": "./dist/plugin.js"
            },
            "require": {
                "types": "./dist/plugin.d.cts",
                "default": "./dist/plugin.cjs"
            },
            "default": "./dist/plugin.js"
        }
    },
    "main": "./dist/plugin.cjs",
    "module": "./dist/plugin.js",
    "types": "./dist/plugin.d.cts",
    "files": [
        "dist",
        "docs/rules",
        "CHANGELOG.md"
    ],
    "workspaces": [
        "docs/docusaurus",
        "packages/*"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && node ./scripts/write-cjs-entry.mjs",
        "build:eslint-inspector": "npx @eslint/config-inspector build --outDir docs/docusaurus/static/eslint-inspector --base /eslint-plugin-tsdoc-require-2/eslint-inspector/",
        "build:eslint-inspector:local": "npx @eslint/config-inspector build --outDir docs/docusaurus/static/eslint-inspector --base /eslint-inspector/",
        "changelog:release-notes": "node ./scripts/changelog-release-notes.mjs",
        "clean": "rimraf coverage dist temp .cache",
        "contrib": "all-contributors",
        "contrib:add": "all-contributors add",
        "contrib:check": "all-contributors check",
        "contrib:compare": "npm run contrib:check",
        "contrib:generate": "all-contributors generate",
        "docs:api": "npm run --workspace docs/docusaurus docs:api",
        "docs:build": "npm run --workspace docs/docusaurus build",
        "docs:check-site-contract": "node packages/docusaurus-site-contract/cli.mjs --config docs/docusaurus/site-contract.config.mjs",
        "docs:site-contract:init": "node packages/docusaurus-site-contract/cli.mjs init --root .",
        "docs:start": "npm run --workspace docs/docusaurus start",
        "lint": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache",
        "lint:compat:eslint": "node ./scripts/eslint-compat-smoke.mjs",
        "lint:compat:eslint10": "npm run lint:compat:eslint -- --expect-eslint-major=10",
        "lint:compat:eslint9": "npm run lint:compat:eslint -- --expect-eslint-major=9",
        "lint:fix": "eslint --cache --cache-strategy content --cache-location .cache/.eslintcache --fix",
        "lint:node-version-files": "node scripts/sync-node-version-files.mjs --check",
        "lint:package:strict": "npm run lint:package-check:strict",
        "lint:package-check": "npm run lint:node-version-files && publint && attw --pack .",
        "lint:package-check:strict": "npm run lint:node-version-files && publint && attw --pack . --profile strict --config-path ./.attw.json",
        "lint:packagelintrc": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
        "lint:prettier": "prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
        "lint:prettier:fix": "prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
        "lint:release": "npm run release:check",
        "release:check": "npm run clean && npm run build && npm run typecheck && npm run lint:fix && npm run lint:prettier:fix && npm run test",
        "sync:node-version-files": "node scripts/sync-node-version-files.mjs",
        "sync:readme": "npm run sync:readme:rules-table && npm run sync:readme:presets-matrix",
        "sync:readme:check": "npm run sync:readme:rules-table:check && npm run sync:readme:presets-matrix:check",
        "sync:readme:presets-matrix": "node ./scripts/sync-presets-rules-matrix.mjs",
        "sync:readme:presets-matrix:check": "node ./scripts/sync-presets-rules-matrix.mjs --check",
        "sync:readme:rules-table": "node ./scripts/sync-readme-rules-table.mjs",
        "sync:readme:rules-table:check": "node ./scripts/sync-readme-rules-table.mjs --check",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.eslint.json --noEmit && tsc -p tsconfig.js.json --noEmit"
    },
    "overrides": {
        "brace-expansion@^1.1.0": "1.1.13",
        "brace-expansion@^2.0.0": "2.0.2",
        "brace-expansion@^5.0.0": "5.0.5",
        "external-editor": {
            "tmp": "0.2.4"
        },
        "yaml": "2.8.3"
    },
    "dependencies": {
        "@typescript-eslint/utils": "^8.58.0"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.2",
        "@docusaurus/eslint-plugin": "^3.9.2",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
        "@eslint-react/eslint-plugin": "^4.2.1",
        "@eslint/compat": "^2.0.3",
        "@eslint/config-helpers": "^0.5.3",
        "@eslint/css": "^1.1.0",
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.2.0",
        "@eslint/markdown": "^8.0.1",
        "@html-eslint/eslint-plugin": "^0.58.1",
        "@html-eslint/parser": "^0.58.1",
        "@microsoft/eslint-plugin-sdl": "^1.1.0",
        "@microsoft/tsdoc-config": "^0.18.1",
        "@softonus/prettier-plugin-duplicate-remover": "^1.1.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "@typescript-eslint/rule-tester": "^8.58.0",
        "@vitest/coverage-v8": "^4.1.2",
        "@vitest/eslint-plugin": "^1.6.14",
        "all-contributors-cli": "^6.26.1",
        "eslint": "^10.1.0",
        "eslint-config-flat-gitignore": "^2.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-array-func": "^5.1.1",
        "eslint-plugin-canonical": "^5.1.3",
        "eslint-plugin-case-police": "^2.2.0",
        "eslint-plugin-comment-length": "^2.3.0",
        "eslint-plugin-css-modules": "^2.12.0",
        "eslint-plugin-de-morgan": "^2.1.1",
        "eslint-plugin-depend": "^1.5.0",
        "eslint-plugin-eslint-plugin": "^7.3.2",
        "eslint-plugin-etc": "^2.0.3",
        "eslint-plugin-file-progress-2": "^3.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-jsonc": "^3.1.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-listeners": "^1.5.1",
        "eslint-plugin-loadable-imports": "^1.0.1",
        "eslint-plugin-math": "^0.13.1",
        "eslint-plugin-module-interop": "^0.3.1",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-nitpick": "^0.12.0",
        "eslint-plugin-no-barrel-files": "^1.2.2",
        "eslint-plugin-no-explicit-type-exports": "^0.12.1",
        "eslint-plugin-no-function-declare-after-return": "^1.1.0",
        "eslint-plugin-no-lookahead-lookbehind-regexp": "^0.4.0",
        "eslint-plugin-no-only-tests": "^3.3.0",
        "eslint-plugin-no-secrets": "^2.3.3",
        "eslint-plugin-no-unsanitized": "^4.1.5",
        "eslint-plugin-no-use-extend-native": "^0.7.2",
        "eslint-plugin-node-dependencies": "^2.2.0",
        "eslint-plugin-package-json": "^0.91.1",
        "eslint-plugin-perfectionist": "^5.8.0",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-redos": "^4.5.0",
        "eslint-plugin-regexp": "^3.1.0",
        "eslint-plugin-require-jsdoc": "^1.0.4",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.2",
        "eslint-plugin-testing-library": "^7.16.2",
        "eslint-plugin-toml": "^1.3.1",
        "eslint-plugin-tsdoc": "^0.5.2",
        "eslint-plugin-tsdoc-require-2": "^1.0.7",
        "eslint-plugin-undefined-css-classes": "^0.1.5",
        "eslint-plugin-unicorn": "^64.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-write-good-comments": "^0.2.0",
        "eslint-plugin-yml": "^3.3.1",
        "globals": "^17.4.0",
        "jsonc-eslint-parser": "^3.1.0",
        "knip": "^6.2.0",
        "picocolors": "^1.1.1",
        "prettier": "^3.8.1",
        "prettier-plugin-ini": "^1.3.0",
        "prettier-plugin-interpolated-html-tags": "^2.0.1",
        "prettier-plugin-jsdoc": "^1.8.0",
        "prettier-plugin-merge": "^0.10.1",
        "prettier-plugin-multiline-arrays": "^4.1.5",
        "prettier-plugin-packagejson": "^3.0.2",
        "prettier-plugin-properties": "^0.3.1",
        "prettier-plugin-sh": "^0.18.0",
        "prettier-plugin-sort-json": "^4.2.0",
        "prettier-plugin-sql": "^0.20.0",
        "prettier-plugin-toml": "^2.0.6",
        "publint": "^0.3.18",
        "recheck-jar": "^4.5.0",
        "rimraf": "^6.1.3",
        "toml-eslint-parser": "^1.0.3",
        "typedoc": "^0.28.17",
        "typescript": "^6.0.2",
        "vite": "^8.0.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.2",
        "yaml-eslint-parser": "^2.0.0"
    },
    "peerDependencies": {
        "@typescript-eslint/parser": "^8.0.0 || ^9.0.0",
        "eslint": "^9.0.0 || ^10.0.0",
        "typescript": ">=5.4.0"
    },
    "packageManager": "npm@11.12.1",
    "engines": {
        "node": ">=20.19.0"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=20.19.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "version": ">=11.0.0",
            "onFail": "error"
        }
    },
    "publishConfig": {
        "provenance": true,
        "registry": "https://registry.npmjs.org/"
    },
    "readme": "README.md"
}
