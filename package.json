{
  "name": "eslint-plugin-tsdoc-require",
  "version": "0.1.0",
  "description": "Require TSDoc comments for exported TypeScript declarations.",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "typescript",
    "tsdoc"
  ],
  "author": "Bruno Marotta",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs/rules",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "changelog:release-notes": "node ./scripts/changelog-release-notes.mjs",
    "clean": "rimraf coverage dist temp",
    "lint": "eslint .",
    "lint:compat:eslint": "node ./scripts/eslint-compat-smoke.mjs",
    "lint:compat:eslint10": "npm run lint:compat:eslint -- --expect-eslint-major=10",
    "lint:compat:eslint9": "npm run lint:compat:eslint -- --expect-eslint-major=9",
    "lint:fix": "eslint . --fix",
    "release:check": "npm run clean && npm run build && npm run typecheck && npm run lint && npm run test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@es-joy/jsdoccomment": "^0.84.0",
    "@typescript-eslint/utils": "^8.56.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@softonus/prettier-plugin-duplicate-remover": "^1.1.2",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/rule-tester": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ini": "^1.3.0",
    "prettier-plugin-interpolated-html-tags": "^2.0.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-merge": "^0.10.0",
    "prettier-plugin-multiline-arrays": "^4.1.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-properties": "^0.3.1",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-sql": "^0.19.2",
    "prettier-plugin-toml": "^2.0.6",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "^8.0.0 || ^9.0.0",
    "eslint": "^9.0.0 || ^10.0.0",
    "typescript": ">=5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
